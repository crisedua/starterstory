# Estos los expone Vite al navegador (todo lo que empieza con VITE_).
# El frontend puede leer datos directamente de Supabase usando el ANON_KEY.
# El SERVICE_ROLE_KEY NUNCA debe estar aquí — solo en backend.
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Solo si despliegas el backend separado del frontend.
# En el setup default (todo en Vercel) déjalo vacío — el frontend y la API
# viven en el mismo origen, así que /api/* funciona directamente.
VITE_API_URL=
